  object SQLQuery1: TSQLQuery
    PacketRecords = 1
    MaxIndexesCount = 4
    FieldDefs = <    
      item
        Name = 'INVENTARIO'
        DataType = ftString
        Precision = -1
        Size = 10
      end    
      item
        Name = 'ELEMENTO'
        DataType = ftString
        Precision = -1
        Size = 60
      end    
      item
        Name = 'SERIE'
        DataType = ftString
        Precision = -1
        Size = 20
      end    
      item
        Name = 'MARCA'
        DataType = ftString
        Precision = -1
        Size = 50
      end    
      item
        Name = 'MODELO'
        DataType = ftString
        Precision = -1
        Size = 20
      end    
      item
        Name = 'FUNCIONARIO'
        DataType = ftString
        Precision = -1
        Size = 80
      end    
      item
        Name = 'DEPENDENCIA'
        DataType = ftString
        Precision = -1
        Size = 40
      end    
      item
        Name = 'ESTADO'
        DataType = ftString
        Precision = -1
        Size = 40
      end    
      item
        Name = 'ID'
        DataType = ftInteger
        Precision = -1
      end    
      item
        Name = 'ASEGURADO'
        DataType = ftFixedChar
        Precision = -1
        Size = 2
      end>
    Transaction = SQLTransaction1
    SQL.Strings = (
      'select elemento.inventario, elemento.descripcion elemento, elemento.serie,'
      'marca.descripcion marca, elemento.modelo, funcionario.apellidos ||  '''' || funcionario.nombres funcionario,'
      'dependencia.descripcion dependencia, estado.descripcion estado, elemento.id,'
      'iif(elemento.id_aseguradora is null, ''No'', ''Si'') Asegurado'
      'from elemento'
      'left join funcionario on (elemento.id_funcionario = funcionario.id)'
      'left join estado on (elemento.id_estado = estado.id)'
      'left join dependencia on (elemento.id_dependencia = dependencia.id)'
      'left outer join marca on (elemento.id_marca = marca.id)'
    )
    Params = <>
    Macros = <>
    Left = 684
    Top = 108
  end
